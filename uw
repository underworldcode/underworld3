    set-env NAME        Change environment directly
    ai-tools            Configure external AI instruction paths

  Building:
    build               Build underworld3
    clean               Clean build artifacts
    petsc-local-build   Build custom PETSc + petsc4py (AMR, ~1 hour)
    petsc-local-clean   Remove custom PETSc build

  Testing:
    test [opts]         Level 1 tests (~2 min, fast mode)
    test-all [opts]     All test levels (~20 min)

    Options pass through to test script:
      --isolation       Run each file in subprocess (thorough)
      --parallel        Include MPI tests (2 ranks)
      --parallel-ranks N  MPI tests with N ranks
      1,2,3             Override test levels

    Examples:
      ./uw test                     Quick level 1, fast mode
      ./uw test --isolation         Level 1 with process isolation
      ./uw test --parallel 2        Level 2 with MPI tests
      ./uw test-all --isolation     All levels, isolated (CI mode)
      ./uw test --help              Show all test options

  Development:
    shell               Interactive pixi shell
    jupyter [args]      Run jupyter (add --worktree NAME to open a worktree)
    format              Run black
    type-check          Run mypy

  Worktrees:
    worktree create <name> [prefix]   Create worktree (symlinks .pixi + PETSc)
    worktree shell <name>             Start shell in worktree directory
    worktree list                     List worktrees with status
    worktree remove <name>            Remove worktree and branch

    Worktrees share the main repo's pixi environment and PETSc build.
    Once inside a worktree shell, ./uw build installs from that source.

  Diagnostics:
    doctor              Check for configuration issues (PETSc mismatch, etc.)
    status              Check for updates on GitHub (without pulling)
    update              Pull latest changes and rebuild

  Any command not listed is passed to: pixi run -e $ENV <command>

FILES

  .pixi-env             Your environment choice (git-ignored)
  pixi.toml             Environment definitions (versioned)
  petsc-custom/petsc/   Custom PETSc build (git-ignored)

EOF
}

# Check for updates on remote (without pulling)
check_for_updates() {
    local quiet="${1:-false}"

    # Check if this is a git repo
    if [ ! -d "$SCRIPT_DIR/.git" ]; then
        [ "$quiet" = "false" ] && echo "Not a git repository"
        return 1
    fi

    cd "$SCRIPT_DIR"

    # Get current branch
    local branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    if [ -z "$branch" ]; then
        [ "$quiet" = "false" ] && echo "Could not determine current branch"
        return 1
    fi

    # Fetch updates from remote (just metadata, no merge)
    if [ "$quiet" = "false" ]; then
        echo "Checking for updates on branch: $branch"
        echo ""
    fi

    git fetch origin "$branch" --quiet 2>/dev/null

    # Count commits behind/ahead
    local behind=$(git rev-list --count HEAD..origin/"$branch" 2>/dev/null || echo "0")
    local ahead=$(git rev-list --count origin/"$branch"..HEAD 2>/dev/null || echo "0")

    if [ "$quiet" = "true" ]; then
        # Return status for quiet mode
        [ "$behind" -gt 0 ] && return 0 || return 1
    fi

    # Show status
    if [ "$behind" -eq 0 ] && [ "$ahead" -eq 0 ]; then
        echo -e "  ${GREEN}✓${NC} Up to date with origin/$branch"
    else
        if [ "$behind" -gt 0 ]; then
            echo -e "  ${YELLOW}↓${NC} $behind commit(s) behind origin/$branch"
            echo ""
            echo "  Recent changes on remote:"
            git log --oneline HEAD..origin/"$branch" | head -5 | sed 's/^/    /'
            local total_behind=$(git rev-list --count HEAD..origin/"$branch")
            [ "$total_behind" -gt 5 ] && echo "    ... and $((total_behind - 5)) more"
        fi
        if [ "$ahead" -gt 0 ]; then
            echo -e "  ${GREEN}↑${NC} $ahead commit(s) ahead of origin/$branch"
        fi
        echo ""
        if [ "$behind" -gt 0 ]; then
            echo "  Run './uw update' to pull changes and rebuild"
        fi
    fi

    # Check for local modifications
    if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
        echo ""
        echo -e "  ${YELLOW}!${NC} You have uncommitted local changes"
    fi

    return 0
}

# Pull updates and rebuild
run_update() {
    cd "$SCRIPT_DIR"

    # Check if this is a git repo
    if [ ! -d "$SCRIPT_DIR/.git" ]; then
        echo "Not a git repository"
        exit 1
    fi

    local branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    echo -e "${BOLD}Updating Underworld3${NC} (branch: $branch)"
    echo ""

    # Check for local changes
    if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
        echo -e "${YELLOW}You have uncommitted local changes:${NC}"
        git status --short
        echo ""
        read -p "Stash changes and continue? [y/N]: " stash_choice
        if [ "$stash_choice" = "y" ] || [ "$stash_choice" = "Y" ]; then
            git stash push -m "uw update: auto-stash $(date +%Y-%m-%d_%H:%M)"
            echo ""
        else
            echo "Commit or stash your changes first, then run './uw update'"
            exit 1
        fi
    fi

    # Pull updates
    echo "Pulling from origin/$branch..."
    if git pull origin "$branch"; then
        echo ""
        echo -e "${GREEN}✓${NC} Pull successful"
        echo ""

        # Rebuild
        read -p "Rebuild underworld3? [Y/n]: " rebuild_choice
        rebuild_choice=${rebuild_choice:-y}
        if [ "$rebuild_choice" = "y" ] || [ "$rebuild_choice" = "Y" ]; then
            echo ""
            run_build
        else
            echo ""
            echo "Run './uw build' when ready to rebuild"
        fi
    else
        echo ""
        echo -e "${YELLOW}Pull failed - check errors above${NC}"
        exit 1
    fi
}

# ── Worktree management ──────────────────────────────────────────────
#
# Worktrees share the main repo's pixi environment and PETSc build
# via symlinks.  `./uw build` from inside a worktree installs the
# worktree's source into the shared env.

WORKTREE_ROOT="$SCRIPT_DIR/.claude/worktrees"

# Resolve the main repo root.  If we ARE a worktree, follow the chain
# back to the principal working tree.
get_main_repo() {
    git -C "$SCRIPT_DIR" worktree list --porcelain 2>/dev/null \
        | head -1 | sed 's/^worktree //'
}

worktree_create() {
    local name="$1"
    local branch_prefix="${2:-feature}"   # feature, bugfix, docs, …

    if [ -z "$name" ]; then
        echo "Usage: ./uw worktree create <name> [branch-prefix]"
        echo ""
        echo "  branch-prefix: feature (default), bugfix, docs, etc."
        echo ""
        echo "Examples:"
        echo "  ./uw worktree create viscoelasticity"
        echo "  ./uw worktree create mesh-fix bugfix"
        exit 1
    fi

    local main_repo=$(get_main_repo)
    local wt_path="$main_repo/.claude/worktrees/$name"
    local branch_name="${branch_prefix}/${name}"

    if [ -d "$wt_path" ]; then
        echo "Worktree '$name' already exists at $wt_path"
        exit 1
    fi

    echo -e "${BOLD}Creating worktree:${NC} $name"
    echo "  Path:   $wt_path"
    echo "  Branch: $branch_name"
    echo ""

    # 1. Create the worktree
    mkdir -p "$main_repo/.claude/worktrees"
    git -C "$main_repo" worktree add "$wt_path" -b "worktree-$name" 2>/dev/null || {
        # Branch may already exist
        git -C "$main_repo" worktree add "$wt_path" "worktree-$name" 2>/dev/null || {
            echo -e "${YELLOW}Failed to create worktree${NC}"
            exit 1
        }
    }

    # 2. Reset to development (worktrees branch from HEAD which may be main)
    echo "  Resetting to origin/development..."
    git -C "$wt_path" fetch origin
    git -C "$wt_path" reset --hard origin/development

    # 3. Rename branch to follow convention
    git -C "$wt_path" branch -m "worktree-$name" "$branch_name" 2>/dev/null || true

    # 4. Symlink shared resources
    echo "  Linking shared environment..."

    # .pixi → main repo's .pixi (shared conda/pip packages)
    if [ -d "$main_repo/.pixi" ]; then
        rm -rf "$wt_path/.pixi"
        ln -s "$main_repo/.pixi" "$wt_path/.pixi"
        echo -e "    ${GREEN}✓${NC} .pixi → main repo"
    fi

    # petsc-custom/petsc → main repo's PETSc build (read-only, not relocatable)
    if [ -d "$main_repo/petsc-custom/petsc" ]; then
        ln -sf "$main_repo/petsc-custom/petsc" "$wt_path/petsc-custom/petsc"
        echo -e "    ${GREEN}✓${NC} petsc-custom/petsc → main repo"
    fi

    # .pixi-env — copy so ./uw knows which environment to use
    if [ -f "$main_repo/.pixi-env" ]; then
        cp "$main_repo/.pixi-env" "$wt_path/.pixi-env"
        echo -e "    ${GREEN}✓${NC} .pixi-env copied ($(cat "$main_repo/.pixi-env"))"
    fi

    echo ""
    echo -e "${GREEN}${BOLD}Worktree ready!${NC}"
    echo ""
    echo "  Start working:  ./uw worktree shell $name"
    echo "  Build:           cd $wt_path && ./uw build"
    echo "  Remove:          ./uw worktree remove $name"
}

worktree_shell() {
    local name="$1"

    if [ -z "$name" ]; then
        echo "Usage: ./uw worktree shell <name>"
        echo ""
        worktree_list
        exit 1
    fi

    local main_repo=$(get_main_repo)
    local wt_path="$main_repo/.claude/worktrees/$name"

    if [ ! -d "$wt_path" ]; then
        echo "Worktree '$name' not found."
        echo ""
        worktree_list
        exit 1
    fi

    local branch=$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
    local env=$(cat "$wt_path/.pixi-env" 2>/dev/null || get_env)

    echo -e "${BOLD}Entering worktree:${NC} $name"
    echo "  Branch: $branch"
    echo "  Env:    $env"
    echo "  Path:   $wt_path"
    echo ""
    echo "  ./uw build   — build from this worktree's source"
    echo "  ./uw test    — run tests"
    echo "  ./uw shell   — pixi shell (if you need raw access)"
    echo "  exit         — leave worktree shell"
    echo ""

    # Start a pixi shell cd'd into the worktree
    cd "$wt_path"
    exec $PIXI shell -e "$env"
}

worktree_list() {
    local main_repo=$(get_main_repo)
    local wt_root="$main_repo/.claude/worktrees"

    echo -e "${BOLD}Worktrees:${NC}"
    echo ""

    if [ ! -d "$wt_root" ]; then
        echo "  (none)"
        echo ""
        echo "Create one:  ./uw worktree create <name>"
        return
    fi

    local found=0
    for d in "$wt_root"/*/; do
        [ ! -d "$d" ] && continue
        local wt_name=$(basename "$d")

        if [ -f "$d/.git" ]; then
            local branch=$(git -C "$d" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
            local status=$(git -C "$d" status --short 2>/dev/null | wc -l | tr -d ' ')
            local linked=$( [ -L "$d/.pixi" ] && echo "linked" || echo "standalone" )
            local dirty=""
            [ "$status" -gt 0 ] && dirty="  ${YELLOW}($status modified)${NC}"

            echo -e "  ${GREEN}${wt_name}${NC}  [$branch]  ($linked)$dirty"
            echo "    $d"
        else
            echo -e "  ${YELLOW}${wt_name}${NC}  (not a git worktree)"
        fi
        found=1
    done

    [ "$found" -eq 0 ] && echo "  (none)"
    echo ""
    echo "Commands:"
    echo "  ./uw worktree create <name>   Create a new worktree"
    echo "  ./uw worktree shell <name>    Start a shell in the worktree"
    echo "  ./uw worktree remove <name>   Remove a worktree"
}

worktree_remove() {
    local name="$1"

    if [ -z "$name" ]; then
        echo "Usage: ./uw worktree remove <name>"
        echo ""
        worktree_list
        exit 1
    fi

    local main_repo=$(get_main_repo)
    local wt_path="$main_repo/.claude/worktrees/$name"

    if [ ! -d "$wt_path" ]; then
        echo "Worktree '$name' not found."
        exit 1
    fi

    local branch=$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    local status=$(git -C "$wt_path" status --short 2>/dev/null | wc -l | tr -d ' ')

    if [ "$status" -gt 0 ]; then
        echo -e "${YELLOW}Worktree has $status uncommitted change(s):${NC}"
        git -C "$wt_path" status --short
        echo ""
        read -p "Remove anyway? [y/N]: " confirm
        [ "$confirm" != "y" ] && [ "$confirm" != "Y" ] && exit 1
    fi

    echo "Removing worktree '$name'..."

    # Must not be cd'd into the worktree
    cd "$main_repo"

    git worktree remove "$wt_path" --force 2>/dev/null || {
        echo -e "${YELLOW}git worktree remove failed — removing manually${NC}"
        rm -rf "$wt_path"
        git worktree prune
    }

    # Delete the branch (use -D because it's merged to development, not main)
    if [ -n "$branch" ] && [ "$branch" != "HEAD" ] && [ "$branch" != "development" ]; then
        git branch -D "$branch" 2>/dev/null && \
            echo -e "  ${GREEN}✓${NC} Deleted branch $branch" || true
    fi

    echo -e "${GREEN}✓${NC} Worktree '$name' removed"
}

# Check if an environment is installed
env_installed() {
    [ -d "$SCRIPT_DIR/.pixi/envs/$1" ]
}

# Check if underworld3 is built in an environment
uw3_built() {
    [ -d "$SCRIPT_DIR/.pixi/envs/$1/lib/python3.12/site-packages/underworld3" ]
}

# Show environment status table
show_env_status() {
    local current_env=$(get_env)
    local has_petsc=$(petsc_built && echo "yes" || echo "no")

    echo "Environments:  (* = selected,  [✓] = uw3 built,  [ ] = needs ./uw build)"
    echo ""

    # Determine platform-default MPI for display
    local default_mpi="mpich"
    [[ "$(uname -s)" == "Darwin" ]] && default_mpi="openmpi"

    for env in default runtime dev amr amr-runtime amr-dev \
               mpich mpich-dev amr-mpich amr-mpich-dev \
               openmpi openmpi-dev amr-openmpi amr-openmpi-dev; do
        # Only show environments that are installed or selected
        if ! env_installed "$env" && [ "$env" != "$current_env" ]; then
            continue
        fi

        # Selected marker
        local marker="  "
        [ "$env" = "$current_env" ] && marker="* "

        # Build status
        local build_status="[ ]"
        if ! env_installed "$env"; then
            build_status="───"  # Not installed
        elif uw3_built "$env"; then
            build_status="[✓]"
        fi

        # Description
        local desc=""
        case "$env" in
            default)         desc="minimal ($default_mpi)" ;;
            runtime)         desc="+ viz, jupyter ($default_mpi)" ;;
            dev)             desc="+ claude, linting ($default_mpi)" ;;
            mpich)           desc="minimal (mpich override)" ;;
            mpich-dev)       desc="+ claude, linting (mpich override)" ;;
            openmpi)         desc="minimal (openmpi override)" ;;
            openmpi-dev)     desc="+ claude, linting (openmpi override)" ;;
            amr)             desc="custom PETSc ($default_mpi)" ;;
            amr-runtime)     desc="custom PETSc + viz ($default_mpi)" ;;
            amr-dev)         desc="custom PETSc + dev ($default_mpi)" ;;
            amr-mpich)       desc="custom PETSc (mpich override)" ;;
            amr-mpich-dev)   desc="custom PETSc + dev (mpich override)" ;;
            amr-openmpi)     desc="custom PETSc (openmpi override)" ;;
            amr-openmpi-dev) desc="custom PETSc + dev (openmpi override)" ;;
        esac

        # AMR note if PETSc not built for this env's arch
        if is_amr_env "$env" && ! petsc_built "$env"; then
            desc="$desc (petsc not built)"
        fi

        printf "  %s%-22s  %s  %s\n" "$marker" "$env" "$build_status" "$desc"
    done
}

# Brief welcome + offer setup
show_welcome() {
    echo -e "${BOLD}Underworld3${NC}"
    echo ""

    # Check for pixi first
    if [ -z "$PIXI" ]; then
        echo "Environment: (pixi not installed)"
        echo ""
        read -p "Run setup to install pixi? [Y/n]: " do_setup
        do_setup=${do_setup:-y}
        if [ "$do_setup" = "y" ] || [ "$do_setup" = "Y" ]; then
            echo ""
            run_setup
        else
            echo ""
            echo "Install pixi from https://pixi.sh then run './uw setup'"
        fi
        return
    fi

    if [ -f "$CONFIG_FILE" ]; then
        show_env_status
        echo ""
        echo "Commands:  ./uw setup   ./uw build   ./uw test   ./uw doctor   ./uw --help"
    else
        echo "Environment: (not configured)"
        echo ""
        read -p "Run setup? [Y/n]: " do_setup
        do_setup=${do_setup:-y}
        if [ "$do_setup" = "y" ] || [ "$do_setup" = "Y" ]; then
            echo ""
            run_setup
        else
            echo ""
            echo "Run './uw setup' when ready, or './uw --help' for options."
        fi
    fi
}

# Main
case "${1:-}" in
    "")
        show_welcome
        ;;
    setup)
        run_setup
        ;;
    set-env)
        if [ -z "$2" ]; then
            echo "Usage: ./uw set-env <environment>"
            echo ""
            echo "Conda-forge PETSc:"
            echo "  MPICH:   default, runtime, dev"
            echo "  OpenMPI: openmpi, openmpi-runtime, openmpi-dev"
            echo ""
            echo "Custom PETSc (AMR):"
            echo "  MPICH:   amr, amr-runtime, amr-dev"
            echo "  OpenMPI: amr-openmpi, amr-openmpi-runtime, amr-openmpi-dev"
            echo ""
            echo "Or run './uw setup' for interactive configuration."
            exit 1
        fi
        echo "$2" > "$CONFIG_FILE"
        echo "Environment: $2"
        echo "Run './uw build' to rebuild underworld3"
        ;;
    shell)
        shift
        exec $PIXI shell -e "$(get_env)" "$@"
        ;;
    jupyter)
        shift
        # Check for --worktree flag
        WORKTREE_DIR=""
        JUPYTER_ARGS=()
        while [ $# -gt 0 ]; do
            case "$1" in
                --worktree)
                    if [ -z "$2" ]; then
                        echo "Usage: ./uw jupyter lab --worktree <name>"
                        echo "Run './uw worktrees' to see available worktrees."
                        exit 1
                    fi
                    WT_NAME="$2"
                    WT_PATH="$SCRIPT_DIR/.claude/worktrees/$WT_NAME"
                    if [ ! -d "$WT_PATH" ]; then
                        echo "Worktree '$WT_NAME' not found at $WT_PATH"
                        echo ""
                        echo "Available worktrees:"
                        if [ -d "$SCRIPT_DIR/.claude/worktrees" ]; then
                            for d in "$SCRIPT_DIR/.claude/worktrees"/*/; do
                                [ -d "$d" ] && echo "  $(basename "$d")"
                            done
                        else
                            echo "  (none)"
                        fi
                        exit 1
                    fi
                    WORKTREE_DIR="$WT_PATH"
                    shift 2
                    ;;
                *)
                    JUPYTER_ARGS+=("$1")
                    shift
                    ;;
            esac
        done
        if [ -n "$WORKTREE_DIR" ]; then
            echo -e "Starting JupyterLab in worktree: ${GREEN}$(basename "$WORKTREE_DIR")${NC}"
            echo "  Path: $WORKTREE_DIR"
            echo ""
            exec $PIXI run -e "$(get_env)" jupyter "${JUPYTER_ARGS[@]}" --notebook-dir="$WORKTREE_DIR"
        else
            exec $PIXI run -e "$(get_env)" jupyter "${JUPYTER_ARGS[@]}"
        fi
        ;;
    worktree)
        shift
        case "${1:-list}" in
            create)  shift; worktree_create "$@" ;;
            shell)   shift; worktree_shell "$@" ;;
            list)    worktree_list ;;
            remove)  shift; worktree_remove "$@" ;;
            *)
                echo "Usage: ./uw worktree <command>"
                echo ""
                echo "Commands:"
                echo "  create <name> [prefix]   Create a new worktree"
                echo "  shell <name>             Start a shell in the worktree"
                echo "  list                     List worktrees (default)"
                echo "  remove <name>            Remove a worktree"
                ;;
        esac
        ;;
    worktrees)
        # Backward compat alias
        worktree_list
        ;;
    build)
        run_build
        ;;
    clean)
        echo "Cleaning build artifacts..."
        rm -rf "$SCRIPT_DIR"/build/lib.* "$SCRIPT_DIR"/build/temp.* "$SCRIPT_DIR"/build/bdist.*
        rm -f "$SCRIPT_DIR/build/.petsc_target"
        echo -e "${GREEN}Done${NC}. Run './uw build' to rebuild."
        ;;
    doctor)
        run_doctor
        ;;
    status)
        check_for_updates
        ;;
    update)
        run_update
        ;;
    ai-tools)
        configure_ai_tools
        ;;
    --help|-h|help)
        show_help
        ;;
    *)
        exec $PIXI run -e "$(get_env)" "$@"
        ;;
esac
